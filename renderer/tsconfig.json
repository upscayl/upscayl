{
  "compilerOptions": {
    "target": "es2020",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "incremental": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "paths": {
      "@/*": [
        "./*"
      ],
      "@common/*": [
        "../common/*"
      ],
      "@components/*": [
        "./components/*"
      ],
      "@lib/utils": [
        "./lib/utils/*"
      ]
    }
  },
  "include": [
    "env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "../app.module.ts",
    "../common/**/*"
  ],
  "exclude": [
    "node_modules"
  ]
}